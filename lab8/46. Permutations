class Solution:
    def permute(self, nums: List[int]) -> List[List[int]]:
        res = []
        current = []
        
        def backtrack():
            if len(current) == len(nums):
                res.append(current.copy())
                return
            
            for num in nums:
                if num not in current:
                    current.append(num)
                    backtrack()
                    current.pop()
                    
        backtrack()
        return res
